# Optional values used by scripts/verify_firebase_rules.sh.
# The Android app itself reads Firebase config from app/google-services.json
# and COUPLE_CANVAS_DATABASE_URL in local.properties.

FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_DATABASE_NAMESPACE=your-project-id-default-rtdb
FIREBASE_DATABASE_EMULATOR_URL=http://127.0.0.1:9000
FIREBASE_AUTH_EMULATOR_URL=http://127.0.0.1:9099/identitytoolkit.googleapis.com/v1

# Required before a public Play Store release. These can also be set in
# local.properties, Gradle properties, or CI environment variables.
LOVEDRAW_PRIVACY_POLICY_URL=https://your-domain.example/privacy
LOVEDRAW_ACCOUNT_DELETION_URL=https://your-domain.example/delete-account
LOVEDRAW_SUPPORT_EMAIL=support@your-domain.example
LOVEDRAW_OPERATOR_NAME=your-public-operator-name
LOVEDRAW_POLICY_EFFECTIVE_DATE=2026-06-08
